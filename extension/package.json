{
  "name": "forkorfry",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "wxt -b firefox",
    "build": "wxt build -b firefox",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons:generate": "python3 scripts/generate-icons.py",
    "package:firefox": "npm run build && rm -f dist/forkorfry-firefox-mv3.xpi && cd dist/firefox-mv3 && zip -r ../forkorfry-firefox-mv3.xpi .",
    "package:source-bundle": "node scripts/package-source-bundle.mjs",
    "package:release": "node scripts/package-release.mjs",
    "validate:release-artifacts": "node scripts/validate-release-artifacts.mjs",
    "preview": "wxt serve -b firefox",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/jsdom": "^28.0.1",
    "eslint": "^9.25.1",
    "globals": "^16.1.0",
    "jsdom": "^29.0.2",
    "typescript-eslint": "^8.31.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "wxt": "^0.20.25"
  }
}
